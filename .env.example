# Coolify injeta PORT automaticamente. Apenas defina se quiser sobrescrever.
PORT=4001

# CORS: 'true' para liberar qualquer origem, ou URL específica.
# No Coolify, manter 'true' é recomendado para evitar problemas de domínio.
CORS_ORIGIN=true

# Opcionais - Rate Limit
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000
